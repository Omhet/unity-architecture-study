.loading-container {
    flex-grow: 1;
    width: 100%;
    height: 100%;
    background-color: rgba(15, 15, 15, 0.95);
    align-items: center;
    justify-content: center;
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

.loading-text {
    color: rgb(255, 255, 255);
    font-size: 48px;
    -unity-font-style: bold;
    letter-spacing: 5px;
}
